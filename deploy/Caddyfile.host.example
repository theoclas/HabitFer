# Ejemplo: Caddy en el HOST de la VPS enrutando Dashboard + HabitFer.
# Copiar a /etc/caddy/Caddyfile (o similar) cuando tengas dominio.
# HabitFer Docker debe usar CADDY_HTTP_PORT=8080 (sin publicar 80/443 en su compose).

# Dashboard (ajusta puertos segun tu instalacion actual)
# dashboard.tudominio.com {
#   handle /api/* {
#     reverse_proxy localhost:4000
#   }
#   handle {
#     reverse_proxy localhost:3000
#   }
# }

# HabitFer (contenedor Caddy en puerto 8080 del host)
# habitfer.tudominio.com {
#   reverse_proxy localhost:8080
# }
