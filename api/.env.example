# Produccion — no usar credenciales de desarrollo
# Copiar a .env.prod y completar con secrets fuertes

PORT=4001
NODE_ENV=production
DATABASE_URL=mysql://USER:STRONG_PASSWORD@db:3306/habitfer
JWT_SECRET=genera_un_secreto_aleatorio_de_al_menos_32_caracteres

# Origen del frontend (debe coincidir con la URL publica)
# Sin dominio:  http://TU_IP:8080
# Con dominio:  https://habitfer.tudominio.com
CORS_ORIGINS=http://TU_IP:8080

# Cookies secure en HTTPS. En HTTP (solo IP:8080) usar false:
COOKIE_SECURE=false

# Aplicar schema al arrancar el contenedor (default true)
PRISMA_DB_PUSH=true
