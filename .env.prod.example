# Copiar a .env en la raiz del proyecto (junto a docker-compose.prod.yml):
#   cp .env.prod.example .env

# --- MySQL (contenedor db) ---
MYSQL_ROOT_PASSWORD=cambia_esto_root_muy_largo
MYSQL_USER=habitfer
MYSQL_PASSWORD=cambia_esto_db_muy_largo

# --- Frontend (build-time) ---
# Sin dominio (convive con Dashboard en puerto 80):
VITE_API_URL=http://TU_IP_VPS:8080/api

# Con dominio HTTPS:
# VITE_API_URL=https://habitfer.tudominio.com/api

# --- Caddy (reverse proxy de HabitFer) ---
# Puerto publico en el host. 8080 evita conflicto con Dashboard en :80
CADDY_HTTP_PORT=8080

# Ruta al Caddyfile: deploy/Caddyfile (HTTP) o deploy/Caddyfile.domain (HTTPS)
CADDYFILE=./deploy/Caddyfile

# Solo si usas Caddyfile.domain (HTTPS directo en este compose):
# DOMAIN=habitfer.tudominio.com
# CADDY_HTTP_PORT=80
# CADDYFILE=./deploy/Caddyfile.domain
